# Database
DATABASE_URL=postgresql+asyncpg://pubai:pubai@localhost:5432/pubai

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Provider — HuggingFace Inference API (OpenAI-compatible)
HF_INFERENCE_URL=
HF_API_TOKEN=

# AI Provider — Ollama (local dev)
OLLAMA_HOST=http://localhost:11434

# Model identifier sent to the inference endpoint
MODEL_IDENTIFIER=

# Auth
SECRET_KEY=change-this-to-random-secret

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Execution sandbox timeout
EXEC_TIMEOUT_SECONDS=10

# Workspace containers (per-agent Kali Linux Docker)
WORKSPACE_ENABLED=true
WORKSPACE_IMAGE=pubai-workspace:latest
WORKSPACE_PRIVILEGED=true
WORKSPACE_CPU_LIMIT=2.0
WORKSPACE_MEMORY_LIMIT=4g
WORKSPACE_IDLE_TIMEOUT_MINUTES=30
WORKSPACE_EXEC_TIMEOUT=120
WORKSPACE_VNC_ENABLED=true
WORKSPACE_VNC_BASE_PORT=6080
WORKSPACE_AUTO_INSTALL=true
